{
  "name": "js-player",
  "version": "1.0.0",
  "description": "Juhi Sohal Player — lightweight JavaScript video player for local and YouTube playback",
  "main": "dist/js-player.umd.js",
  "module": "dist/js-player.es.js",
  "exports": {
    ".": {
      "import": "./dist/js-player.es.js",
      "require": "./dist/js-player.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev":           "vite",
    "build":         "vite build --config vite.app.config.js",
    "build:lib":     "vite build",
    "preview":       "vite preview --config vite.app.config.js",
    "test":          "vitest run --config vitest.config.js",
    "test:watch":    "vitest --config vitest.config.js",
    "test:coverage": "vitest run --config vitest.config.js --coverage",
    "test:e2e":      "vitest run --config vitest.e2e.config.js",
    "lint":          "eslint src --ext .js",
    "format":        "prettier --write src demo",
    "cap:sync":      "npm run build && npx cap sync",
    "cap:android":   "npm run cap:sync && npx cap open android",
    "cap:ios":       "npm run cap:sync && npx cap open ios"
  },
  "keywords": [
    "video",
    "player",
    "youtube",
    "html5",
    "media",
    "mobile",
    "capacitor"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "playwright": "^1.61.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
